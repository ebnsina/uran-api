# Uran API configuration. Every variable is REQUIRED — there are no defaults or
# fallbacks; the process refuses to start if any is missing or malformed.
# Copy to .env and adjust for your environment.

URAN_ADDR=:8080
URAN_DATABASE_URL=postgres://user@127.0.0.1:5432/uran?sslmode=disable
URAN_SESSION_TTL=720h
URAN_SHUTDOWN_TIMEOUT=15s
URAN_ENV=development
URAN_GITHUB_WEBHOOK_SECRET=change-me
URAN_REGISTRY=localhost:5005
URAN_BUILD_WORKDIR=/tmp/uran-builds

# Controller (cmd/controller) — reconciles deploys onto Kubernetes
URAN_KUBECONFIG=/path/to/kubeconfig.yaml
URAN_BASE_DOMAIN=uran.local
URAN_CERT_ISSUER=uran-selfsigned   # cert-manager ClusterIssuer for TLS

# Note: each process only requires the variables it uses —
#   api:        URAN_ADDR, URAN_DATABASE_URL, URAN_SESSION_TTL, URAN_SHUTDOWN_TIMEOUT, URAN_ENV, URAN_GITHUB_WEBHOOK_SECRET
#   builder:    URAN_DATABASE_URL, URAN_ENV, URAN_REGISTRY, URAN_BUILD_WORKDIR
#   controller: URAN_DATABASE_URL, URAN_ENV, URAN_KUBECONFIG, URAN_BASE_DOMAIN, URAN_CERT_ISSUER
