[Unit]
Description=Uran Kubernetes controller (reconciles deploys → k8s)
After=network-online.target uran-api.service
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/root/uran-api
EnvironmentFile=/root/uran-api/.env
ExecStart=/usr/local/bin/uran-controller
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
